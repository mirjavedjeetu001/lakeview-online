RewriteEngine On

# Point all traffic to Laravel public directory
RewriteCond %{REQUEST_URI} !^/lakeview/public/
RewriteRule ^(.*)$ /lakeview/public/$1 [L]

# Handle trailing slashes
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(.*)$ /lakeview/public/index.php [L]
